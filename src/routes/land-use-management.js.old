/**
 * Land Use Management API Routes
 * CRUD operations for managing land uses, zones, and development matrix
 */

async function landUseManagementRoutes(fastify) {
  
  // ============================================
  // LAND USE GROUPS CRUD
  // ============================================

  // GET /api/land-use/groups
  // List all land use groups with pagination and filtering
  fastify.get('/groups', {
    schema: {
      description: 'List all land use groups',
      tags: ['Land Use Management'],
      querystring: {
        type: 'object',
        properties: {
          page: { type: 'number', minimum: 1, default: 1 },
          limit: { type: 'number', minimum: 1, maximum: 100, default: 20 },
          search: { type: 'string', description: 'Search by code or description' },
          category: { type: 'string', enum: ['residential', 'commercial', 'industrial', 'institutional', 'recreational', 'agricultural', 'mixed'] },
          is_active: { type: 'boolean' }
        }
      },
      response: {
        200: {
          type: 'object',
          properties: {
            success: { type: 'boolean' },
            data: { type: 'array' },
            pagination: {
              type: 'object',
              properties: {
                page: { type: 'number' },
                limit: { type: 'number' },
                total: { type: 'number' },
                totalPages: { type: 'number' }
              }
            }
          }
        }
      }
    }
  }, async (request, reply) => {
    try {
      const { page = 1, limit = 20, search, category, is_active } = request.query
      const offset = (page - 1) * limit

      // Build WHERE clause
      let whereClause = 'WHERE 1=1'
      const params = []
      let paramIndex = 1

      if (search) {
        whereClause += ` AND (group_code ILIKE $${paramIndex} OR description ILIKE $${paramIndex} OR notes ILIKE $${paramIndex})`
        params.push(`%${search}%`)
        paramIndex++
      }

      if (category) {
        whereClause += ` AND group_category = $${paramIndex}`
        params.push(category)
        paramIndex++
      }

      if (is_active !== undefined) {
        whereClause += ` AND is_active = $${paramIndex}`
        params.push(is_active)
        paramIndex++
      }

      // Get total count
      const countQuery = `SELECT COUNT(*) as total FROM land_use_groups ${whereClause}`
      const countResult = await fastify.pg.query(countQuery, params)
      const total = parseInt(countResult.rows[0].total)

      // Get paginated data
      const dataQuery = `
        SELECT * FROM land_use_groups 
        ${whereClause} 
        ORDER BY group_code 
        LIMIT $${paramIndex} OFFSET $${paramIndex + 1}
      `
      params.push(limit, offset)
      
      const { rows } = await fastify.pg.query(dataQuery, params)

      return {
        success: true,
        data: rows,
        pagination: {
          page: parseInt(page),
          limit: parseInt(limit),
          total,
          totalPages: Math.ceil(total / limit)
        }
      }
    } catch (error) {
      fastify.log.error('Error fetching land use groups:', error)
      reply.status(500)
      return {
        success: false,
        error: 'Failed to fetch land use groups',
        message: error.message
      }
    }
  })

  // GET /api/land-use/groups/:id
  // Get a specific land use group
  fastify.get('/groups/:id', {
    schema: {
      description: 'Get a specific land use group',
      tags: ['Land Use Management'],
      params: {
        type: 'object',
        properties: {
          id: { type: 'number' }
        }
      }
    }
  }, async (request, reply) => {
    try {
      const { id } = request.params
      
      const { rows } = await fastify.pg.query(
        'SELECT * FROM land_use_groups WHERE group_id = $1',
        [id]
      )

      if (rows.length === 0) {
        reply.status(404)
        return {
          success: false,
          error: 'Land use group not found'
        }
      }

      return {
        success: true,
        data: rows[0]
      }
    } catch (error) {
      fastify.log.error('Error fetching land use group:', error)
      reply.status(500)
      return {
        success: false,
        error: 'Failed to fetch land use group',
        message: error.message
      }
    }
  })

  // POST /api/land-use/groups
  // Create a new land use group
  fastify.post('/groups', {
    schema: {
      description: 'Create a new land use group',
      tags: ['Land Use Management'],
      body: {
        type: 'object',
        required: ['group_code', 'description', 'group_category'],
        properties: {
          group_code: { type: 'string', minLength: 1, maxLength: 10 },
          description: { type: 'string', minLength: 1, maxLength: 255 },
          short_name: { type: 'string', maxLength: 100 },
          group_category: { type: 'string', enum: ['residential', 'commercial', 'industrial', 'institutional', 'recreational', 'agricultural', 'mixed'] },
          typical_floor_area_sqm: { type: 'number', minimum: 0 },
          typical_height_meters: { type: 'number', minimum: 0 },
          notes: { type: 'string' },
          is_active: { type: 'boolean', default: true }
        }
      }
    }
  }, async (request, reply) => {
    try {
      const groupData = request.body
      
      // Check if group code already exists
      const existingGroup = await fastify.pg.query(
        'SELECT group_id FROM land_use_groups WHERE group_code = $1',
        [groupData.group_code.toUpperCase()]
      )

      if (existingGroup.rows.length > 0) {
        reply.status(400)
        return {
          success: false,
          error: 'Group code already exists'
        }
      }

      const { rows } = await fastify.pg.query(`
        INSERT INTO land_use_groups (
          group_code, description, short_name, group_category,
          typical_floor_area_sqm, typical_height_meters, notes, is_active,
          created_at, updated_at
        ) VALUES (
          $1, $2, $3, $4, $5, $6, $7, $8, NOW(), NOW()
        ) RETURNING *
      `, [
        groupData.group_code.toUpperCase(),
        groupData.description,
        groupData.short_name || null,
        groupData.group_category,
        groupData.typical_floor_area_sqm || null,
        groupData.typical_height_meters || null,
        groupData.notes || null,
        groupData.is_active !== undefined ? groupData.is_active : true
      ])

      reply.status(201)
      return {
        success: true,
        data: rows[0]
      }
    } catch (error) {
      fastify.log.error('Error creating land use group:', error)
      reply.status(500)
      return {
        success: false,
        error: 'Failed to create land use group',
        message: error.message
      }
    }
  })

  // PUT /api/land-use/groups/:id
  // Update a land use group
  fastify.put('/groups/:id', {
    schema: {
      description: 'Update a land use group',
      tags: ['Land Use Management'],
      params: {
        type: 'object',
        properties: {
          id: { type: 'number' }
        }
      },
      body: {
        type: 'object',
        properties: {
          description: { type: 'string', minLength: 1, maxLength: 255 },
          short_name: { type: 'string', maxLength: 100 },
          group_category: { type: 'string', enum: ['residential', 'commercial', 'industrial', 'institutional', 'recreational', 'agricultural', 'mixed'] },
          typical_floor_area_sqm: { type: 'number', minimum: 0 },
          typical_height_meters: { type: 'number', minimum: 0 },
          notes: { type: 'string' },
          is_active: { type: 'boolean' }
        }
      }
    }
  }, async (request, reply) => {
    try {
      const { id } = request.params
      const updateData = request.body

      // Check if group exists
      const existingGroup = await fastify.pg.query(
        'SELECT group_id FROM land_use_groups WHERE group_id = $1',
        [id]
      )

      if (existingGroup.rows.length === 0) {
        reply.status(404)
        return {
          success: false,
          error: 'Land use group not found'
        }
      }

      // Build dynamic update query
      const updateFields = []
      const params = []
      let paramIndex = 1

      Object.keys(updateData).forEach(key => {
        if (updateData[key] !== undefined) {
          updateFields.push(`${key} = $${paramIndex}`)
          params.push(updateData[key])
          paramIndex++
        }
      })

      if (updateFields.length === 0) {
        reply.status(400)
        return {
          success: false,
          error: 'No valid fields to update'
        }
      }

      updateFields.push(`updated_at = NOW()`)
      params.push(id)

      const { rows } = await fastify.pg.query(`
        UPDATE land_use_groups 
        SET ${updateFields.join(', ')}
        WHERE group_id = $${paramIndex}
        RETURNING *
      `, params)

      return {
        success: true,
        data: rows[0]
      }
    } catch (error) {
      fastify.log.error('Error updating land use group:', error)
      reply.status(500)
      return {
        success: false,
        error: 'Failed to update land use group',
        message: error.message
      }
    }
  })

  // DELETE /api/land-use/groups/:id
  // Soft delete a land use group
  fastify.delete('/groups/:id', {
    schema: {
      description: 'Delete a land use group',
      tags: ['Land Use Management'],
      params: {
        type: 'object',
        properties: {
          id: { type: 'number' }
        }
      }
    }
  }, async (request, reply) => {
    try {
      const { id } = request.params

      // Check if group exists
      const existingGroup = await fastify.pg.query(
        'SELECT group_id FROM land_use_groups WHERE group_id = $1',
        [id]
      )

      if (existingGroup.rows.length === 0) {
        reply.status(404)
        return {
          success: false,
          error: 'Land use group not found'
        }
      }

      // Soft delete by setting is_active to false
      const { rows } = await fastify.pg.query(`
        UPDATE land_use_groups 
        SET is_active = false, updated_at = NOW()
        WHERE group_id = $1
        RETURNING *
      `, [id])

      return {
        success: true,
        data: rows[0],
        message: 'Land use group deleted successfully'
      }
    } catch (error) {
      fastify.log.error('Error deleting land use group:', error)
      reply.status(500)
      return {
        success: false,
        error: 'Failed to delete land use group',
        message: error.message
      }
    }
  })

  // ============================================
  // LAND USE ZONES CRUD
  // ============================================

  // GET /api/land-use/zones
  fastify.get('/zones', {
    schema: {
      description: 'List all land use zones',
      tags: ['Land Use Management'],
      querystring: {
        type: 'object',
        properties: {
          page: { type: 'number', minimum: 1, default: 1 },
          limit: { type: 'number', minimum: 1, maximum: 100, default: 20 },
          local_authority_id: { type: 'number' }
        }
      }
    }
  }, async (request, reply) => {
    try {
      const { page = 1, limit = 20, local_authority_id } = request.query
      const offset = (page - 1) * limit

      let whereClause = 'WHERE 1=1'
      const params = []
      let paramIndex = 1

      if (local_authority_id) {
        whereClause += ` AND local_authority_id = $${paramIndex}`
        params.push(local_authority_id)
        paramIndex++
      }

      const countQuery = `SELECT COUNT(*) as total FROM land_use_zones ${whereClause}`
      const countResult = await fastify.pg.query(countQuery, params)
      const total = parseInt(countResult.rows[0].total)

      const dataQuery = `
        SELECT lz.*, la.name as local_authority_name 
        FROM land_use_zones lz
        LEFT JOIN local_authorities la ON lz.local_authority_id = la.local_authority_id
        ${whereClause} 
        ORDER BY lz.zone_code 
        LIMIT $${paramIndex} OFFSET $${paramIndex + 1}
      `
      params.push(limit, offset)
      
      const { rows } = await fastify.pg.query(dataQuery, params)

      return {
        success: true,
        data: rows,
        pagination: {
          page: parseInt(page),
          limit: parseInt(limit),
          total,
          totalPages: Math.ceil(total / limit)
        }
      }
    } catch (error) {
      fastify.log.error('Error fetching land use zones:', error)
      reply.status(500)
      return {
        success: false,
        error: 'Failed to fetch land use zones',
        message: error.message
      }
    }
  })

  // ============================================
  // DEVELOPMENT MATRIX CRUD
  // ============================================

  // GET /api/land-use/matrix
  fastify.get('/matrix', {
    schema: {
      description: 'List development matrix rules',
      tags: ['Land Use Management'],
      querystring: {
        type: 'object',
        properties: {
          zone_id: { type: 'number' },
          group_id: { type: 'number' },
          permission_type: { type: 'string', enum: ['permitted', 'conditional', 'prohibited'] }
        }
      }
    }
  }, async (request, reply) => {
    try {
      const { zone_id, group_id, permission_type } = request.query

      let whereClause = 'WHERE 1=1'
      const params = []
      let paramIndex = 1

      if (zone_id) {
        whereClause += ` AND dm.zone_id = $${paramIndex}`
        params.push(zone_id)
        paramIndex++
      }

      if (group_id) {
        whereClause += ` AND dm.group_id = $${paramIndex}`
        params.push(group_id)
        paramIndex++
      }

      if (permission_type) {
        whereClause += ` AND dm.permission_type = $${paramIndex}`
        params.push(permission_type)
        paramIndex++
      }

      const { rows } = await fastify.pg.query(`
        SELECT dm.*, lz.zone_name, lg.description as group_description, lg.group_code
        FROM development_matrix dm
        LEFT JOIN land_use_zones lz ON dm.zone_id = lz.zone_id
        LEFT JOIN land_use_groups lg ON dm.group_id = lg.group_id
        ${whereClause}
        ORDER BY lz.zone_name, lg.group_code
      `, params)

      return {
        success: true,
        data: rows
      }
    } catch (error) {
      fastify.log.error('Error fetching development matrix:', error)
      reply.status(500)
      return {
        success: false,
        error: 'Failed to fetch development matrix',
        message: error.message
      }
    }
  })

  // POST /api/land-use/matrix
  fastify.post('/matrix', {
    schema: {
      description: 'Create a development matrix rule',
      tags: ['Land Use Management'],
      body: {
        type: 'object',
        required: ['zone_id', 'group_id', 'permission_type'],
        properties: {
          zone_id: { type: 'number' },
          group_id: { type: 'number' },
          permission_type: { type: 'string', enum: ['permitted', 'conditional', 'prohibited'] },
          conditions: { type: 'string' },
          min_floor_area: { type: 'number', minimum: 0 },
          max_floor_area: { type: 'number', minimum: 0 },
          min_height: { type: 'number', minimum: 0 },
          max_height: { type: 'number', minimum: 0 },
          notes: { type: 'string' }
        }
      }
    }
  }, async (request, reply) => {
    try {
      const matrixData = request.body

      // Check if rule already exists
      const existingRule = await fastify.pg.query(
        'SELECT matrix_id FROM development_matrix WHERE zone_id = $1 AND group_id = $2',
        [matrixData.zone_id, matrixData.group_id]
      )

      if (existingRule.rows.length > 0) {
        reply.status(400)
        return {
          success: false,
          error: 'Development matrix rule already exists for this zone and group combination'
        }
      }

      const { rows } = await fastify.pg.query(`
        INSERT INTO development_matrix (
          zone_id, group_id, permission_type, conditions,
          min_floor_area, max_floor_area, min_height, max_height, notes,
          created_at, updated_at
        ) VALUES (
          $1, $2, $3, $4, $5, $6, $7, $8, $9, NOW(), NOW()
        ) RETURNING *
      `, [
        matrixData.zone_id,
        matrixData.group_id,
        matrixData.permission_type,
        matrixData.conditions || null,
        matrixData.min_floor_area || null,
        matrixData.max_floor_area || null,
        matrixData.min_height || null,
        matrixData.max_height || null,
        matrixData.notes || null
      ])

      reply.status(201)
      return {
        success: true,
        data: rows[0]
      }
    } catch (error) {
      fastify.log.error('Error creating development matrix rule:', error)
      reply.status(500)
      return {
        success: false,
        error: 'Failed to create development matrix rule',
        message: error.message
      }
    }
  })
}

module.exports = landUseManagementRoutes
