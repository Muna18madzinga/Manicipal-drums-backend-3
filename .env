# Database
DATABASE_URL=postgresql://postgres:cairo2025@localhost:5432/vungu_master_db_v1
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vungu_master_db_v1
DB_USER=postgres
DB_PASSWORD=cairo2025
# Server
PORT=3000
ADMIN_PORT=3001
NODE_ENV=development
# JWT
JWT_SECRET=vungu-super-secret-jwt-key-change-in-production_jan_2026
# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000
FRONTEND_URL=http://localhost:5175
# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1m

# ============================================================
# OGC Services Configuration (QGIS Server Integration)
# ============================================================

# QGIS Server URL (Docker: http://qgis-server:80, Local: http://localhost:8080)
QGIS_SERVER_URL=http://localhost:8080

# QGIS Project file path (relative to QGIS Server)
QGIS_PROJECT=/etc/qgisserver/vungu-docker-minimal.qgs

# OGC Service Versions
WMS_VERSION=1.3.0
WFS_VERSION=2.0.0
WMTS_VERSION=1.0.0

# Default Coordinate Reference System
DEFAULT_SRS=EPSG:4326

# Request Configuration
OGC_TIMEOUT=30000
OGC_MAX_RETRIES=3
MAX_FEATURES=10000

