# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/vungu_master_db_v1

# Server
PORT=3000
NODE_ENV=development

# JWT â€” must be at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# In production the server refuses to boot if this still contains
# 'change-in-production' (see src/middleware/jwtAuth.js).
JWT_SECRET=replace-with-48-byte-random-base64-secret

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1m

# NVIDIA NIM (free API catalog) â€” powers /api/planning/suggest LLM layout suggestions.
# Get a free key (1000 credits / 40 RPM) at https://build.nvidia.com â€” no card required.
# Server-side only; never exposed to the browser. Unset â‡’ the endpoint returns 503 and the
# Planning Studio falls back to its offline deterministic generator.
NVIDIA_API_KEY=

# QGIS Server Configuration
QGIS_SERVER_URL=http://localhost:8080
QGIS_SERVER_VERSION=1.3.0
QGIS_PROJECT=/vungu-project.qgs
QGIS_SERVER_TIMEOUT=30000
QGIS_SERVER_MAX_RETRIES=3

# â”€â”€ Paynow (Slice A: mobile money via Express Checkout) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Sandbox values from https://developers.paynow.co.zw/ . Replace with
# the production Vungu RDC merchant credentials before shipping.
PAYNOW_INTEGRATION_ID=12345
PAYNOW_INTEGRATION_KEY=aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee
PAYNOW_API_BASE=https://www.paynow.co.zw
PAYNOW_RESULT_URL=http://localhost:3000/api/payments/webhook/paynow
PAYNOW_RETURN_URL=http://localhost:5174/payment/return

# â”€â”€ Claude (Anthropic) AI: document verification + email fine-tuning â”€
# Get an API key at https://console.anthropic.com (Settings â†’ API Keys).
# Leave ANTHROPIC_API_KEY blank to disable AI: document verification falls
# back to manual staff review and confirmation emails use the plain template.
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01
# Defaults favour low latency. Set the vision model to a Sonnet model
# (e.g. claude-sonnet-4-6) for stronger document reading.
ANTHROPIC_TEXT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_VISION_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_TIMEOUT_MS=30000

# â”€â”€ Document verification â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Which verifier runs when a citizen uploads an ID / supporting document.
#   manual  â€” leave in 'under_review' for a staff member to pass/fail (default)
#   claude  â€” Claude vision checks legibility + extracts ID fields, then
#             ALWAYS hands the document to staff with a pass/fail/uncertain
#             recommendation (the AI never makes the final decision).
ID_VERIFIER=clauden
# Confidence floor (0â€“1) for the AI to recommend a "pass" to the reviewer.
AI_VERIFY_THRESHOLD=0.7

# â”€â”€ Email delivery (application-received + status notifications) â”€â”€â”€â”€â”€
# The outbox worker drains notifications_outbox. In dev it prints to the
# console; set MAIL_TRANSPORT=smtp + SMTP_* to actually send.
MAIL_WORKER_INPROC=1
MAIL_TRANSPORT=console
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@vungurdc.gov.zw
FRONTEND_URL=http://localhost:5174
