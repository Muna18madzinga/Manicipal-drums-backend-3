# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/vungu_master_db_v1

# Server
PORT=3000
NODE_ENV=development

# JWT — must be at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# In production the server refuses to boot if this still contains
# 'change-in-production' (see src/middleware/jwtAuth.js).
JWT_SECRET=replace-with-48-byte-random-base64-secret

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1m

# QGIS Server Configuration
QGIS_SERVER_URL=http://localhost:8080
QGIS_SERVER_VERSION=1.3.0
QGIS_PROJECT=/vungu-project.qgs
QGIS_SERVER_TIMEOUT=30000
QGIS_SERVER_MAX_RETRIES=3

# ── Paynow (Slice A: mobile money via Express Checkout) ───────────
# Sandbox values from https://developers.paynow.co.zw/ . Replace with
# the production Vungu RDC merchant credentials before shipping.
PAYNOW_INTEGRATION_ID=12345
PAYNOW_INTEGRATION_KEY=aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee
PAYNOW_API_BASE=https://www.paynow.co.zw
PAYNOW_RESULT_URL=http://localhost:3000/api/payments/webhook/paynow
PAYNOW_RETURN_URL=http://localhost:5174/payment/return
